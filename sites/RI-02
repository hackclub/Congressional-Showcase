  <script>
    // Theme toggle
    const themeToggle = document.getElementById('themeToggle');
    const htmlElement = document.documentElement;
    const bodyElement = document.body;


    // Check saved theme preference
    const savedTheme = localStorage.getItem('theme') || 'dark';
    if (savedTheme === 'light') {
      bodyElement.classList.add('light-mode');
      themeToggle.textContent = '🌞 Dark Mode';
    }


    themeToggle.addEventListener('click', () => {
      bodyElement.classList.toggle('light-mode');
      const isLightMode = bodyElement.classList.contains('light-mode');
      themeToggle.textContent = isLightMode ? '🌞 Dark Mode' : '🌙 Light Mode';
      localStorage.setItem('theme', isLightMode ? 'light' : 'dark');
    });


    // Tilt effect
    const h1 = document.querySelector('.tilt-element');
    const maxRotation = 30;
   
    document.addEventListener('mousemove', (e) => {
      const rect = h1.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
     
      const mouseX = e.clientX;
      const mouseY = e.clientY;
     
      const distX = ((mouseX - centerX) / window.innerWidth) * maxRotation;
      const distY = ((mouseY - centerY) / window.innerHeight) * maxRotation;
     
      h1.style.transform = `perspective(1000px) rotateX(${-distY}deg) rotateY(${distX}deg)`;
    });
   
    document.addEventListener('mouseleave', () => {
      h1.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
    });


    // Sticker effect
    const stickers = [
      { text: 'Education', emoji: '📚' },
      { text: 'Planning', emoji: '📅' },
      { text: 'Scheduling', emoji: '⏰' },
      { text: 'Tasks', emoji: '✅' },
      { text: 'Goals', emoji: '🎯' },
      { text: 'Time', emoji: '⏳' },
      { text: 'Progress', emoji: '📈' },
      { text: 'Study', emoji: '🎓' }
    ];


    const stickerColors = [
      { bg: '#91D37E', text: '#777777', border: '#91D37E' },
      { bg: '#3A7D96', text: '#777777', border: '#3A7D96' },
      { bg: '#4B9BB9', text: '#777777', border: '#4B9BB9' }
    ];


    let lastStickerTime = 0;
    const stickerDelay = 200;


    const heroDiv = document.querySelector('.hero');
   
    heroDiv.addEventListener('mousemove', (e) => {
      const now = Date.now();
      if (now - lastStickerTime < stickerDelay) return;
      lastStickerTime = now;


      const randomSticker = stickers[Math.floor(Math.random() * stickers.length)];
      const randomColor = stickerColors[Math.floor(Math.random() * stickerColors.length)];


      const sticker = document.createElement('div');
      sticker.className = 'sticker';
      sticker.innerHTML = `${randomSticker.emoji} ${randomSticker.text}`;
      sticker.style.left = e.clientX + 'px';
      sticker.style.top = e.clientY + 'px';
      sticker.style.backgroundColor = randomColor.bg;
      sticker.style.color = randomColor.text;
      sticker.style.border = `2px solid ${randomColor.border}`;
     
      const randomTX = (Math.random() - 0.5) * 120;
      const randomRot = (Math.random() - 0.5) * 45;
     
      sticker.style.setProperty('--tx', randomTX + 'px');
      sticker.style.setProperty('--rot', randomRot + 'deg');


      document.body.appendChild(sticker);


      setTimeout(() => {
        sticker.remove();
      }, 2500);
    });
  </script>
