    color: var(--light);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    perspective: 700px;
    overflow-x: hidden;
    transition: background-color 4s ease, color 4s ease;
    position: relative;
}


body.light-mode {
    background: linear-gradient(135deg, #F5F7FA 0%, #E8F0F8 100%);
    color: var(--light-text);
    transition: background-color 4s ease, color 4s ease;
}


/* Background decorations */
body::before {
    content: '';
    position: fixed;
    top: 20%;
    left: 10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(155, 126, 201, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
}


body::after {
    content: '';
    position: fixed;
    bottom: 20%;
    right: 10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 107, 157, 0.08) 0%, transparent 70%);
